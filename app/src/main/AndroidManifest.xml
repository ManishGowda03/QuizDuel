<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".QuizDuelApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.QuizDuel"
        android:forceDarkAllowed="false"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".ui.splash.SplashActivity"
            android:exported="true"
            android:noHistory="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.QuizDuel.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.auth.LoginActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.auth.RegisterActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.home.HomeActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.QuizDuel.Home"
            android:windowSoftInputMode="adjustPan" />

        <activity
            android:name=".ui.quiz.QuizActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.QuizDuel.Home"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.result.ResultActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.QuizDuel.Home"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.admin.AdminActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.QuizDuel.Admin"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.duel.QuickMatchActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.CreateRoomActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.JoinRoomActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.WaitingLobbyActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleResultActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.RematchNegotiateActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleReviewActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.friends.FriendsActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.friends.InviteTopicPickerActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleHistoryActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleHistoryDetailActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait" />

        <activity
            android:name=".ui.duel.BattleInstructionsActivity"
            android:theme="@style/Theme.QuizDuel.Home"
            android:screenOrientation="portrait"/>

    </application>

</manifest>