<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="20dp"
    android:layout_marginVertical="10dp"
    app:cardBackgroundColor="@color/clay_white"
    app:cardCornerRadius="24dp"
    app:cardElevation="6dp"> <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvTopicName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fontFamily="sans-serif-bold"
            android:letterSpacing="0.05"
            android:textAllCaps="true"
            android:textColor="@color/clay_text_muted"
            android:textSize="12sp"
            tools:text="JAVA BASICS" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/clay_text_muted"
            android:textSize="12sp"
            tools:text="24 Mar 2026" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginVertical="12dp"
        android:background="#10000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivMyAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_difficulty_badge"
                android:backgroundTint="#E8EAFF"
                android:padding="6dp" />

            <TextView
                android:id="@+id/tvMyName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-bold"
                android:maxLines="1"
                android:textColor="@color/clay_text_dark"
                android:textSize="14sp"
                tools:text="You" />

            <TextView
                android:id="@+id/tvMyScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/clay_primary"
                android:textSize="24sp"
                tools:text="150" /> </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tvResult"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textColor="@color/clay_white"
                android:textSize="12sp"
                tools:background="@drawable/circle_red_bg"
                tools:text="WIN" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="sans-serif-black"
                android:text="VS"
                android:textColor="@color/clay_text_muted"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/ivOppAvatar"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/bg_difficulty_badge"
                android:backgroundTint="#E8EAFF"
                android:padding="6dp" />

            <TextView
                android:id="@+id/tvOppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:fontFamily="sans-serif-bold"
                android:maxLines="1"
                android:textColor="@color/clay_text_dark"
                android:textSize="14sp"
                tools:text="Bharath" />

            <TextView
                android:id="@+id/tvOppScore"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/clay_text_dark"
                android:textSize="24sp"
                tools:text="120" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
</androidx.cardview.widget.CardView>